DATABASE_URL=file:./data/skatoday.db

# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=defina-um-secret-de-pelo-menos-32-chars

# Chave separada pra cofre de senhas. NUNCA rotacionar sem migrar dados — perde acesso.
SECRETS_KEY=defina-outro-secret-de-pelo-menos-32-chars

# URL pública (usada nos links de reset de senha)
PUBLIC_BASE_URL=http://localhost:3000

# Pasta dos uploads (imagens dos clientes). Em produção é volume Docker.
UPLOADS_DIR=./data/uploads

# SMTP (Stalwart Mail Few Company). Sem isso, emails vão pro stdout em dev.
# SMTP_HOST=mail.fewcompany.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=skatoday@fewcompany.com
